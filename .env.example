# ============================================================================
# VACCINE PANDA - VPS DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================================================

# -------------------
# NODE.JS CONFIGURATION
# -------------------
NODE_ENV=production
PORT=3000

# -------------------
# CLERK AUTHENTICATION
# -------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# -------------------
# TURSO DATABASE (Edge SQLite)
# -------------------
TURSO_DATABASE_URL=libsql://your-database-url.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# -------------------
# JWT AUTH (For Staff/Admin Login)
# -------------------
JWT_SECRET=your_random_long_string_here_for_jwt_tokens

# -------------------
# WHATSAPP INTEGRATION
# -------------------
WHATSAPP_VERIFY_TOKEN=vaccine_panda_wa_verify
KILO_WEBHOOK_URL=https://your-domain.com/api/webhooks/whatsapp

# -------------------
# PAYU PAYMENT GATEWAY
# -------------------
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_salt

# -------------------
# VPS-SPECIFIC CONFIGURATION
# -------------------
# These are optional but can be useful for VPS deployment

# Database file path (only needed if using local SQLite instead of Turso)
# DB_URL=file:./data/panda.db

# SSL Configuration (handled by Nginx/Certbot)
# HTTPS=true

# Logging Level
# LOG_LEVEL=info

# Rate Limiting
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=900000